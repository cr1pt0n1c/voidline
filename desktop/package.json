{
  "name": "voidline-desktop",
  "version": "0.1.0",
  "description": "Voidline desktop app - E2E encrypted chat, no accounts, no server-side history",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "license": "MIT",
  "dependencies": {
    "libsodium-wrappers-sumo": "^0.8.4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.voidline.desktop",
    "productName": "Voidline",
    "files": [
      "main.js",
      "preload.js",
      "crypto.js",
      "store.js",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
